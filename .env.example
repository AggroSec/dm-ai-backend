# =========================
# Database
# =========================
DB_URL=postgres://user:password@localhost/dungeonmaster?sslmode=disable
DB_USER=dmuser
DB_PASSWORD=dmpass
DB_NAME=dungeonmaster

# =========================
# Auth
# =========================
# Used to sign and verify JWT tokens
# Generate a strong random string - never reuse this across projects
# Example command to generate one: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# How long access tokens last (e.g. 15m, 1h, 24h)
JWT_EXPIRY=15m

# How long refresh tokens last before requiring re-login
JWT_REFRESH_EXPIRY=168h

# =========================
# AI / OpenRouter
# =========================
# Get your free API key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model to use - can swap this without changing code
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Max tokens the AI can return per response
OPENROUTER_MAX_TOKENS=1000

# =========================
# Server
# =========================
PORT=8080

# Environment: development or production
APP_ENV=development
